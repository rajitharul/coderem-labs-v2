# Zoho SMTP — Get Started contact form (lib/email.ts)
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# In production, set these in Vercel → Settings → Environment Variables.

SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=praveen@coderemlabs.com
SMTP_PASS=your-zoho-app-password
SMTP_FROM="Praveen - CodeREM Labs <praveen@coderemlabs.com>"
CONTACT_EMAIL=praveen@coderemlabs.com

# Google Analytics 4 — GA loads only when this is set (app/layout.tsx)
# Find your Measurement ID in GA4 → Admin → Data Streams → your web stream.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
